# ==========================
# Sub2Api 中转站环境变量配置
# ==========================
# 复制此文件为 .env 并填写实际值：
#   cp .env.example .env
#   nano .env

# Redis 密码（随机生成一个强密码）
REDIS_PASSWORD=please_change_this_password

# Cloudflare Tunnel Token
# 获取方式：https://one.dash.cloudflare.com/ → Networks → Tunnels → 创建 Tunnel
TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# WARP SOCKS5 代理地址（默认端口 40000，一般不需要修改）
WARP_PROXY=socks5h://172.17.0.1:40000
